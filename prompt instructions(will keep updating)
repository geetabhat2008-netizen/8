### CompareImage component

```tsx
function CompareImage({
  comp, index,
}: {
  comp: typeof COMPETITORS[0]
  index: number
}) {
  const [errored, setErrored] = useState(false)

  return (
    <motion.div
      initial={{ opacity: 0, y: 12 }}
      whileInView={{ opacity: 1, y: 0 }}
      viewport={{ once: true, margin: '-40px' }}
      transition={{ duration: 0.5, delay: index * 0.07, ease: 'ease' }}
      style={{
        display: 'flex',
        flexDirection: 'column',
        alignItems: 'flex-start',
        gap: '10px',
      }}
    >

      {/* Image cell */}
      <div style={{
        width: '100%',
        aspectRatio: comp.isCrownCalm ? '3/4' : '4/3',
        borderRadius: '6px',
        overflow: 'hidden',
        border: comp.isCrownCalm
          ? '1.5px solid rgba(210,182,247,0.7)'   /* lavender border */
          : '1px solid rgba(26,26,26,0.08)',
        filter: comp.isCrownCalm ? 'none' : 'grayscale(35%) opacity(0.75)',
        transition: 'filter 200ms ease',
        background: comp.isCrownCalm ? '#D2B6F718' : '#EBE4DB',
        position: 'relative',
      }}>

        {/* Phase shimmer on CrownCalm only */}
        {comp.isCrownCalm && (
          <div style={{
            position: 'absolute', inset: 0,
            background: 'linear-gradient(145deg, rgba(210,182,247,0.08) 0%, transparent 60%)',
            pointerEvents: 'none', zIndex: 1,
          }} />
        )}

        {errored ? (
          <div style={{
            width: '100%', height: '100%',
            display: 'flex', alignItems: 'center', justifyContent: 'center',
            background: comp.isCrownCalm ? '#D2B6F718' : '#EBE4DB',
          }}>
            <span style={{
              fontFamily: 'Space Mono, monospace',
              fontSize: '8px', color: '#BEBAB4',
              letterSpacing: '0.1em', textTransform: 'uppercase',
              textAlign: 'center', padding: '0 8px',
            }}>
              {comp.name}
            </span>
          </div>
        ) : (
          <Image
            src={comp.image.src}
            alt={comp.image.alt}
            fill
            style={{ objectFit: 'cover' }}
            onError={() => setErrored(true)}
          />
        )}

      </div>

      {/* Product name below image */}
      <div>
        <p style={{
          fontFamily: comp.isCrownCalm
            ? 'Playfair Display, Georgia, serif'
            : 'Space Mono, monospace',
          fontSize: comp.isCrownCalm ? '14px' : '10px',
          fontWeight: comp.isCrownCalm ? 400 : 700,
          fontStyle: comp.isCrownCalm ? 'italic' : 'normal',
          color: comp.isCrownCalm ? '#1A1A1A' : '#999999',
          letterSpacing: comp.isCrownCalm ? '-0.01em' : '0.1em',
          textTransform: comp.isCrownCalm ? 'none' : 'uppercase',
          margin: '0 0 3px',
        }}>
          {comp.name}
        </p>
        <p style={{
          fontFamily: 'Space Mono, monospace',
          fontSize: '9px', color: '#BEBAB4',
          letterSpacing: '0.08em', textTransform: 'uppercase',
          margin: 0,
        }}>
          {comp.subtitle}
        </p>
      </div>

    </motion.div>
  )
}
```


              textAlign: 'center',
            }}>
              <span style={{
                fontFamily: 'Space Mono, monospace',
                fontSize: comp.isCrownCalm ? '16px' : '14px',
                fontWeight: 700,
                color: comp.isCrownCalm ? '#1A1A1A' : '#BEBAB4',
                letterSpacing: '-0.02em',
              }}>
                {comp.isCrownCalm
                  ? `${score} / 5`
                  : `${score}${partial > 0 ? `+${partial}` : ''} / 5`
                }
              </span>
            </td>
          )
        })}
      </tr>

    </tbody>
  </table>
</div>

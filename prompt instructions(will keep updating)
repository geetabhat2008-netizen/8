          </td>

          {/* Result cells */}
          {COMPETITORS.map((comp, compIndex) => {
            const result = comp.results[mechIndex]
            const config = RESULT_CONFIG[result]

            return (
              <td key={comp.name} style={{
                padding: '14px 8px',
                borderBottom: '1px solid rgba(26,26,26,0.07)',
                textAlign: 'center',
                /* CrownCalm column: subtle left border */
                borderLeft: comp.isCrownCalm
                  ? '1px solid rgba(26,26,26,0.10)'

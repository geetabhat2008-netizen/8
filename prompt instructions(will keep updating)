            {comp.isCrownCalm ? 'CrownCalm' : ''}
            {/* Competitors have no text in header — image strip serves as header */}
          </th>
        ))}
      </tr>
    </thead>

    <tbody>
      {MECHANISMS.map((mech, mechIndex) => (
        <motion.tr
          key={mech.label}
          initial={{ opacity: 0, x: -8 }}
          whileInView={{ opacity: 1, x: 0 }}
          viewport={{ once: true, margin: '-20px' }}
          transition={{
            duration: 0.45,
            delay: mechIndex * 0.06,
            ease: 'ease',
          }}
          style={{
            background: mechIndex % 2 === 0
              ? `${mech.color}08`   /* very faint phase tint on alternating rows */
              : 'transparent',
          }}
        >

          {/* Mechanism label cell */}
          <td style={{
            padding: '14px 0',
            borderBottom: '1px solid rgba(26,26,26,0.07)',
          }}>
            <div style={{ display: 'flex', alignItems: 'center', gap: '10px' }}>

              {/* Phase color bar — left edge indicator */}
              <div style={{
                width: '4px', height: '20px',
                borderRadius: '2px',
                background: mech.color,
                flexShrink: 0,
              }} />

              <span style={{
                fontFamily: 'Space Mono, monospace',
